import dbConnect from '@/utils/dbConnect';
import Doctor from '@/models/Doctor';
import type { NextApiRequest, NextApiResponse } from 'next';

const getDoctorsBySpecialty = async (specialty: string) => {
  try {
    await dbConnect();
    const doctors = await Doctor.find({ specialty }).lean();  // lean() is fine for performance
    return doctors;
  } catch (error) {
    console.error('Error fetching doctors:', error);
    return [];
  }
};

export default async function handler(req: NextApiRequest, res: NextApiResponse) {
  const { specialty } = req.query;

  // Ensure the specialty is a string
  if (!specialty || typeof specialty !== 'string') {
    return res.status(400).json({ message: 'Specialty is required and must be a string.' });
  }

  const doctors = await getDoctorsBySpecialty(specialty);
           
  if (doctors.length === 0) {
    return res.status(404).json({ message: `No doctors found for ${specialty}` });
  }

  return res.status(200).json(doctors);
}









