const AppointmentDetails = async ({ params }: { params: { id: string } }) => {
  // Debug log to check the received params
  console.log("Received Params:", params);

  // Validate params and the id
  if (!params?.id || !mongoose.Types.ObjectId.isValid(params.id)) {
    console.error("Invalid or missing appointment ID:", params?.id);
    return (
      <div className="min-h-screen flex items-center justify-center">
        <p className="text-red-500 text-lg">Invalid or missing appointment ID!</p>
      </div>
    );
  }

  // Connect to the database
  await dbConnect();

  let appointment;
  try {
    // Attempt to fetch the appointment by ID
    appointment = await Appointment.findById(params.id).lean();
    if (!appointment) {
      console.error("No appointment found for the provided ID:", params.id);
      return (
        <div className="min-h-screen flex items-center justify-center">
          <p className="text-red-500 text-lg">No appointment found!</p>
        </div>
      );
    }
  } catch (error) {
    // Log and handle any errors during the fetch process
    console.error("Error fetching appointment:", error);
    return (
      <div className="min-h-screen flex items-center justify-center">
        <p className="text-red-500 text-lg">An error occurred while fetching the appointment!</p>
      </div>
    );
  }

  // If appointment exists, render the details
  return (
    <div className="min-h-screen bg-gradient-to-b from-gray-50 to-gray-100 flex items-center justify-center px-6 py-12">
      <div className="bg-white shadow-2xl rounded-3xl p-8 max-w-2xl w-full relative">
        <h1 className="text-4xl font-extrabold text-center text-gray-900 mb-8 mt-8 tracking-wide">
