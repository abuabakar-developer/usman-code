          <DetailRow label="Age" value={appointment.age} />
          <DetailRow label="Email" value={appointment.email} />
          <DetailRow label="Contact" value={appointment.contact} />
          <DetailRow label="Service" value={appointment.service} />
        </div>
      </div>
    </div>
  );
};

