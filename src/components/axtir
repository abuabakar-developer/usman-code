"use client";
import Image from "next/image";
import { useState, ChangeEvent, FormEvent } from "react";
import { useRouter } from "next/navigation";
import { toast } from "react-toastify";
import "react-toastify/dist/ReactToastify.css";

interface MedicineFormData {
  medicines: string;
  prescription: File | null;
  address: string;
  mobile: string;
  patientName: string;
  city: string;
}

const MedicinePage: React.FC = () => {
  const router = useRouter();

  const [formData, setFormData] = useState<MedicineFormData>({
    medicines: "",
    prescription: null,
    address: "",
    mobile: "",
    patientName: "",
    city: "",
  });

  const [selectedOption, setSelectedOption] = useState<"medicines" | "prescription" | null>(null);

  const handleInputChange = (e: ChangeEvent<HTMLInputElement | HTMLSelectElement>) => {
    const { name, value } = e.target;
    setFormData({ ...formData, [name]: value });
  };

  const handleFileChange = (e: ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0] || null;
    setFormData({ ...formData, prescription: file });
  };

  const handleOptionSelect = (option: "medicines" | "prescription") => {
    setSelectedOption(option);
    setFormData({ ...formData, medicines: "", prescription: null });
  };

  const handleSubmit = async (e: FormEvent<HTMLFormElement>) => {
    e.preventDefault();

    // Validate inputs
    if (selectedOption === "medicines" && !formData.medicines.trim()) {
      toast.error("Please enter medicines or select a prescription.", {
        position: "top-center",
        autoClose: 3000,
      });
      return;
    }

    if (selectedOption === "prescription" && !formData.prescription) {
      toast.error("Please upload a prescription or enter medicines.", {
        position: "top-center",
        autoClose: 3000,
      });
      return;
    }

    // Message for the owner
    const ownerMessage = `New medicine order received:\nMedicines: ${
      formData.medicines || "Attached prescription"
    }\nPatient: ${formData.patientName}\nAddress: ${formData.address}\nMobile: ${
      formData.mobile
    }\nCity: ${formData.city}`;

    try {
      const res = await fetch("/api/send-sms", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({ message: ownerMessage }),
      });

      if (res.ok) {
        toast.success("Order placed successfully and owner notified!", {
          position: "top-center",
          autoClose: 3000,
        });

        setTimeout(() => {
          router.push("/orderconfirm");
        }, 2000); // Redirect after 2 seconds
      } else {
        toast.error("Failed to notify the owner.", {
          position: "top-center",
          autoClose: 3000,
        });
      }
    } catch (error) {
      console.error("Error notifying owner:", error);
      toast.error("An error occurred while notifying the owner.", {
        position: "top-center",
        autoClose: 3000,
      });
    }

    setFormData({
      medicines: "",
      prescription: null,
      address: "",
      mobile: "",
      patientName: "",
      city: "",
    });
    setSelectedOption(null);
  };

  return (
    <div className="flex flex-col items-center bg-gray-50 min-h-screen px-4 py-6 sm:px-6 lg:px-8">
      <h1 className="text-4xl font-extrabold text-green-600 text-center mb-6">Abcare Medicine</h1>
      <div className="relative w-64 h-64 sm:w-80 sm:h-80 lg:w-96 lg:h-96">
        <Image
          src="/abcare.webp"
          alt="Abcare Medicine"
          layout="fill"
          objectFit="contain"
          className="rounded-lg shadow-md"
        />
      </div>

      <h2 className="text-3xl font-bold text-green-600 text-center mt-10">Order Medicines</h2>
      <form onSubmit={handleSubmit} className="w-full max-w-lg bg-white shadow-lg rounded-xl p-6 mt-6 space-y-6">
        <div>
          <label htmlFor="medicines" className="block text-gray-700 font-medium">
            Enter Medicines
          </label>
          <input
            type="text"
            id="medicines"
            name="medicines"
            value={formData.medicines}
            onChange={handleInputChange}
            disabled={selectedOption === "prescription"}
            required={selectedOption === "medicines"}
            placeholder="E.g., Paracetamol 500mg, Cough Syrup"
            className={`w-full px-4 py-3 border ${selectedOption === "prescription" ? "bg-gray-100" : "border-gray-300"} rounded-lg focus:outline-none focus:ring-2 focus:ring-green-400`}
          />
        </div>

        <div className="flex items-center justify-center my-4">
          <button
            type="button"
            className="px-4 py-2 bg-green-600 text-white font-semibold rounded-lg hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-green-500"
            onClick={() => handleOptionSelect(selectedOption === "medicines" ? "prescription" : "medicines")}
          >
            OR
          </button>
        </div>

        <div>
          <label htmlFor="prescription" className="block text-gray-700 font-medium">
            Attach Prescription
          </label>
          <input
            type="file"
            id="prescription"
            name="prescription"
            onChange={handleFileChange}
            disabled={selectedOption === "medicines"}
            required={selectedOption === "prescription"}
            className={`w-full px-4 py-3 border ${selectedOption === "medicines" ? "bg-gray-100" : "border-gray-300"} rounded-lg focus:outline-none focus:ring-2 focus:ring-green-400`}
          />
        </div>

        {["address", "mobile", "patientName", "city"].map((field, index) => (
          <div key={index}>
            <label htmlFor={field} className="block text-gray-700 font-medium capitalize">
              {field.replace(/([A-Z])/g, " $1")}
            </label>
            <input
              type={field === "mobile" ? "tel" : "text"}
              id={field}
              name={field}
              value={(formData as any)[field]}
              onChange={handleInputChange}
              required
              className="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-400"
            />
          </div>
        ))}

        <button
          type="submit"
          className="w-full px-4 py-3 bg-green-600 text-white font-semibold rounded-lg hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-green-500"
        >
          Submit Order
        </button>
      </form>
    </div>
  );
};

export default MedicinePage;





