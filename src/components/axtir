          <div
            key={index}
            className={`p-6 sm:p-8 bg-white shadow-xl rounded-lg hover:shadow-2xl hover:-translate-y-2 transform transition duration-300 ${
              selectedSpecialty === specialty.title ? 'border-2 border-blue-500' : ''
